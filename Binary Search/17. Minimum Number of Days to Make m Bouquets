/*
1482. Minimum Number of Days to Make m Bouquets
Time  :  O(n log(maxBloomDay))
Space : O(1)
*/

    //m = number of Bouquet to make (required)
    //k = number of flowers
    int NoOfBouquet(vector<int>& bloomDay, int day, int k){
        int num = 0, counter = 0;
        for(int i = 0; i < bloomDay.size(); i++){
            if(bloomDay[i] <= day){
                counter++;
            }else{
                num += (counter/k);
                counter = 0;
            }
        }
        num += (counter/k);
        return num;
    }
    int minDays(vector<int>& bloomDay, int m, int k) {
        int ans = -1, n = bloomDay.size();
        int low = *min_element(bloomDay.begin(), bloomDay.end());
        int high = *max_element(bloomDay.begin(), bloomDay.end());

        //handle edge case: not enough elements in the array
        if((long long)m * k > bloomDay.size()){
            return -1;
        }

        //start Binary Search to find the answer
        while(low<=high){
            int mid = low+(high-low)/2;
            int bouquets = NoOfBouquet(bloomDay, mid, k); 
            if(bouquets >= m){
                ans = mid;
                high = mid-1;
            }else{
                low = mid+1;
            }
        }
        return ans;
    }
